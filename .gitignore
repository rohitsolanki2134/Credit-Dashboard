# ── Secrets & credentials — NEVER commit these ────────────────────────────────
.env
*.env.local
.streamlit/secrets.toml

# ── Database — included so history travels with the repo ──────────────────────
# *.db  ← intentionally NOT excluded (credit_dashboard.db is committed)

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
streamlit_err.log
streamlit_out.log

# ── Dev / test scratch files ──────────────────────────────────────────────────
_test_*.py
_diag_*.py
*.bak

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
